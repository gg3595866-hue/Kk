{
  "manifest_version": 2,
  "name": "1xBet Game Proxy",
  "version": "1.0.0",
  "description": "Intercepts and proxies 1xBet game requests so games load inside the app.",

  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "storage",
    "activeTab",
    "*://*.1x-bet.mobi/*",
    "*://*.1xbet.com/*",
    "*://*.traincdn.com/*",
    "*://*.v3.traincdn.com/*",
    "<all_urls>"
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],

  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "1xBet Game Proxy"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

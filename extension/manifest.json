{
  "manifest_version": 2,
  "name": "Lucky Patcher + 1xBet Proxy",
  "version": "2.0.0",
  "description": "Full network inspector with built-in 1xBet game proxy. Captures all traffic, strips framing headers, and routes 1x-bet.mobi through your proxy.",

  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "storage",
    "tabs",
    "activeTab",
    "alarms",
    "notifications",
    "proxy",
    "*://*/*"
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },

  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content-script.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],

  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_title": "Lucky Patcher + 1xBet"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": ["injected.js"]
}
